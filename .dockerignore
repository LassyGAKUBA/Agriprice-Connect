# Dependencies — Docker installs these fresh inside the container
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment files — NEVER put secrets in a Docker image
.env
.env.*
.env.local
.env.production

# Git files — not needed inside container
.git/
.gitignore

# Docker files themselves — no need to copy these into the image
Dockerfile
Dockerfile.frontend
docker-compose.yml
docker-compose.*.yml
.dockerignore

# Logs
logs/
*.log

# Testing files — not needed in production image
coverage/
.nyc_output/
__tests__/
*.test.js
*.spec.js

# Editor files
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Temporary files
tmp/
temp/
